<?xml version="1.0" encoding="utf-8" ?>
<!--
  Code entry screen — custom-rendered keypad (Roku's Button node renders
  unreliably across firmware). Layout retuned so the keypad fits inside
  1080p without overlapping the help text at the bottom.

  Vertical budget (1920x1080 FHD):
    60- 165  logo poster      (105 tall)
   185- 245  title label
   265- 305  tagline label
   335- 475  digit-slot row   (140 tall)
   510- 955  keypad           (4 rows of 100 + 3 gaps of 15 = 445 tall)
   985-1015  help label
-->
<component name="CodeEntryScene" extends="Group">

    <interface>
        <field id="submittedCode" type="string" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/CodeEntryScene.brs" />

    <children>
        <!-- Transparent-background logo. We ship a separate asset
             (images/logo.png) rather than reusing icon_fhd.png because
             the icon is padded to 4:3 with a slate fill for Roku's home
             screen — wrong shape and wrong background for this scene. -->
        <Poster id="logoPoster"
            uri="pkg:/images/logo.png"
            translation="[890,60]"
            width="140"
            height="140"
            loadDisplayMode="scaleToFit" />

        <Label id="titleLabel"
            text="BrewerBoard"
            translation="[560,185]"
            width="800"
            horizAlign="center"
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF" />

        <Label id="taglineLabel"
            text="Enter your 6-digit screen code"
            translation="[560,265]"
            width="800"
            horizAlign="center"
            font="font:MediumSystemFont"
            color="0xFFFFFFAA" />

        <!-- Digit slot row, populated by buildDigitSlots() at translation
             x=595 so a 730px-wide row centers on the 1920 screen. -->
        <Group id="digitRow" translation="[595,335]" />

        <!-- Keypad grid, populated by buildKeypad() at translation x=670
             so a 580px-wide 3-column grid centers on the screen. -->
        <Group id="keypadGroup" translation="[670,510]" />

        <Label id="helpLabel"
            text="D-pad to move, OK to select"
            translation="[560,985]"
            width="800"
            horizAlign="center"
            color="0xFFFFFF55" />
    </children>
</component>
