<?xml version="1.0" encoding="utf-8" ?>
<!--
  Code entry screen — rewritten to ditch the built-in Button node, which
  doesn't render its text reliably across Roku firmware versions (was
  showing up as a tiny dot on a TCL Roku TV). Instead we draw each keypad
  cell as a Group of Rectangle + Label and handle D-pad focus + OK press
  in BrightScript via onKeyEvent.

  Visual hierarchy mirrors the web /display entry page:
    - BrewerBoard logo (top center)
    - Title + tagline
    - 6 large digit slots
    - 4x3 numeric keypad with custom focusable cells
    - Help text (single short line)
-->
<component name="CodeEntryScene" extends="Group">

    <interface>
        <field id="submittedCode" type="string" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/CodeEntryScene.brs" />

    <children>
        <!-- Channel logo (reuses the FHD icon we ship for the home screen) -->
        <Poster id="logoPoster"
            uri="pkg:/images/icon_fhd.png"
            translation="[890,80]"
            width="140"
            height="105"
            loadDisplayMode="scaleToFit" />

        <Label id="titleLabel"
            text="BrewerBoard"
            translation="[660,210]"
            width="600"
            horizAlign="center"
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF" />

        <Label id="taglineLabel"
            text="Enter your 6-digit screen code"
            translation="[560,290]"
            width="800"
            horizAlign="center"
            font="font:MediumSystemFont"
            color="0xFFFFFF99" />

        <!-- Digit-slot row, populated by buildDigitSlots() -->
        <Group id="digitRow" translation="[510,380]" />

        <!-- Custom keypad grid, populated by buildKeypad() -->
        <Group id="keypadGroup" translation="[660,580]" />

        <Label id="helpLabel"
            text="D-pad to move, OK to select"
            translation="[460,1010]"
            width="1000"
            horizAlign="center"
            color="0xFFFFFF55" />
    </children>
</component>
