<?xml version="1.0" encoding="utf-8" ?>
<!--
  DisplayScene — taplist render. Matches the web display's "image panel +
  taplist column" layout when the operator has columns=2 + a column
  image set, and reads colors / visibility toggles from screen.config.

  Layout decisions all live in computeLayout() in the .brs file — XML
  just exposes the nodes we mutate at runtime.
-->
<component name="DisplayScene" extends="Group">

    <interface>
        <field id="screenCode" type="string" />
        <field id="requestSignOut" type="boolean" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/DisplayScene.brs" />

    <children>
        <!-- Full-screen bg whose color we override from
             screen.config.background_color once a payload arrives. -->
        <Rectangle id="rootBg" width="1920" height="1080" color="0x1C1917FF" />

        <!-- Header bar: just centered text. Dropped the brewery logo
             (web display doesn't show one in the header) and the "Live"
             status indicator (was operator-distracting noise). -->
        <Rectangle id="headerBg" width="1920" height="100" color="0x00000040" />
        <Label id="headerText"
            text=""
            translation="[0,30]"
            width="1920"
            horizAlign="center"
            font="font:LargestBoldSystemFont"
            color="0xFFFFFFFF" />

        <!-- Body container — image panel and/or beer columns get appended
             here at runtime. Cleared on every render. -->
        <Group id="bodyContainer" translation="[0,120]" />

        <!-- Footer bar + ticker. The Label sits inside a clipping Group
             so we can scroll the text off-screen on both sides. -->
        <Rectangle id="footerBg" translation="[0,1020]" width="1920" height="60" color="0x00000040" />
        <Group id="footerClip" translation="[0,1020]" >
            <Label id="footerText"
                text=""
                translation="[1920,15]"
                font="font:MediumSystemFont"
                color="0xFFFFFFFF" />
        </Group>

        <!-- Polling timer — fires every 30s to refetch the payload. -->
        <Timer id="refreshTimer"
            repeat="true"
            duration="30"
            control="start" />

        <!-- Ticker animation. Translates the footer label horizontally
             from off-screen-right to off-screen-left, then loops. We
             rebuild the Vector2DFieldInterpolator's keyValue at runtime
             once we know the rendered text width. -->
        <Animation id="tickerAnim" duration="20" repeat="true" easeFunction="linear">
            <Vector2DFieldInterpolator
                id="tickerInterp"
                key="[0.0, 1.0]"
                keyValue="[ [1920.0, 15.0], [-2000.0, 15.0] ]"
                fieldToInterp="footerText.translation" />
        </Animation>
    </children>
</component>
