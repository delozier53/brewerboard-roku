<?xml version="1.0" encoding="utf-8" ?>
<!--
  DisplayScene — taplist render that mirrors the web display layout:
    ┌────────────────────────┬────────────────────────────────────┐
    │                        │  Header 1     |     Header 2        │
    │   Column image         │  ──────────────────────────────     │
    │   (slideshow)          │  [logo]  Beer Name | Brewery   12oz │
    │                        │          Style · ABV · IBU      $5  │
    │                        │  ──────────────────────────────     │
    │                        │  ...                                │
    └────────────────────────┴────────────────────────────────────┘
       this is a sample      here's another one      anniversary

  Headers live INSIDE the tap-list panel (not as a global header
  bar), matching the web. No brewery logo in the chrome. No "Live"
  status indicator. The 3-message footer is rendered as a scrolling
  marquee using an Animation node.
-->
<component name="DisplayScene" extends="Group">

    <interface>
        <field id="screenCode" type="string" />
        <field id="requestSignOut" type="boolean" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/DisplayScene.brs" />

    <children>
        <Rectangle id="rootBg" width="1920" height="1080" color="0x1C1917FF" />

        <!-- Body container spans the full screen above the footer.
             All panels (image, tap list) are appended here at runtime
             and cleared on every render. -->
        <Group id="bodyContainer" translation="[0,0]" />

        <!-- Footer marquee. footerText is a DIRECT CHILD of the scene
             (not nested in a clipping group) so the Animation's
             fieldToInterp="footerText.translation" path resolves
             correctly. Previously it was nested in footerClip and the
             animation silently failed — all messages rendered at their
             initial positions because the interpolator never fired. -->
        <Rectangle id="footerBg" translation="[0,1010]" width="1920" height="70" color="0x00000033" />
        <Label id="footerText"
            text=""
            translation="[1920,1030]"
            font="font:MediumSystemFont"
            color="0xFFFFFFFF" />

        <Timer id="refreshTimer"
            repeat="true"
            duration="30"
            control="start" />

        <Animation id="tickerAnim" duration="20" repeat="true" easeFunction="linear">
            <Vector2DFieldInterpolator
                id="tickerInterp"
                key="[0.0, 1.0]"
                keyValue="[ [1920.0, 1030.0], [-2000.0, 1030.0] ]"
                fieldToInterp="footerText.translation" />
        </Animation>
    </children>
</component>
